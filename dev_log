		        /*2022.08.17 가수금분개요청일시 추가(생존지급,계약변경요청)*/

		        SELECT COUNT(A.PYIO_PRCS_APLC_SUID) AS CNT           /*  1.입출금처리신청상세_입출금처리신청SUID 건수*/
		          FROM IPMOWN.TBL_IPMIPPPPAP A     /*입출금처리신청*/
		             , IPMOWN.TBL_IPMIPPPPAD B     /*입출금처리신청상세*/
		             , IPMOWN.TBL_IPMIPPITDR C     /*즉시이체청구결과*/
		         WHERE 1 = 1
		           AND A.DLTN_YN                       = 'N'
		           AND B.DLTN_YN                       = 'N'
		           AND C.DLTN_YN                       = 'N'
		           AND C.PYIO_PRCS_STTS_CODE          != '9'
		           AND A.PYIO_PRCS_APLC_SUID           = B.PYIO_PRCS_APLC_SUID
		           AND A.PYIO_PRCS_APLC_SUID           = C.IMDT_TRSF_BING_RSLT_SUID
		           AND C.IMDT_TRSF_RSLT_CODE           IN ('0','1')             /*18.즉시이체결과코드[VARCHAR2(10)] */
		         
		         
		         
		           AND A.BSWR_DVSN_CODE                = 'BAC'                 /*9.업무구분코드[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND A.PRSN_GROU_DVSN_CODE           = '1'             /*10.개인단체구분코드[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND A.CUST_ID                       = '5052759605'                       /*11.고객ID[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND A.ACTL_TRNN_CUST_ID             = '5052759605'               /*12.실거래고객ID[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND A.PRCS_ORGN_CODE                = '00477'                 /*13.처리기관코드[VARCHAR2(5)] */
		         
		         
		         
		         
		           AND A.HNDR_EMNB                     = '2130070'                     /*14.처리자사원번호[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND A.PYIO_MTHD_DVSN_CODE           = '68'             /*15.입출금방법구분코드[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND A.PYIO_CHNL_DVSN_CODE           = '02'             /*17.입출금채널구분코드[VARCHAR2(10)] */
		         
		         


		         
		         
		           AND B.RFRN_BSWR_DVSN_CODE_VAL1      = 'RLTM_DPST_SUID'         /*10.참조업무구분코드값1[VARCHAR2(100)] */
		         
		         
		         
		         
		           AND B.RFRN_BSWR_DVSN_CODE_VAL2      = 'RLTM_DPST_GROP_SUID'         /*11.참조업무구분코드값2[VARCHAR2(100)] */
		         
		         
		         
		         
		         
		         
		           AND B.RFRN_BSWR_VAL1                = '300014462151'                 /*14.참조업무값1[VARCHAR2(100)] */
		         
		         
		         
		         
		           AND B.RFRN_BSWR_VAL2                = '300006635902'                 /*15.참조업무값2[VARCHAR2(100)] */
		         
		         
		         
		         
		         
		         
		           AND B.PYIO_PRCS_AMT                 = 200000                  /*18.입출금처리금액[NUMBER(22)] */
		         
		         
		         
		         
		         
		           AND B.MGMT_NO                       = '126336198'                       /*20.관리번호[VARCHAR2(20)] */
		         
		         
		         
		         



		         
		         
		           AND C.FNNC_ORGN_DVSN_CODE           = '1'             /*11.금융기관구분코드[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND C.FNNC_ORGN_CODE                = '004'                 /*12.금융기관코드[VARCHAR2(10)] */
		         
		         
		         
		         
		           AND C.STLM_MEAN_SUID                = 1100000000029519861                 /*13.결제수단SUID[NUMBER(22)] */
		         
		         
		         
		         
		           AND C.IMDT_TRSF_BING_AMT            = 200000              /*14.즉시이체청구금액[NUMBER(22)] */
		         
		         
		         
		         
		         
		         
		         
		         
		         
		           AND C.PYIO_PRCS_STTS_CODE           = '1'             /*24.입출금처리상태코드[VARCHAR2(10)] */
		         
		         
		         
		         

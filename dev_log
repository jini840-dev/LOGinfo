pmImdtTrsfPSI009c] [198.18.0.121] hone.log.query.mybatis.MybatisLogInterceptor [  85] : [IPM198018001175202605291743547611110] /*SQL_ID: hlicp.ipm.dsi.intgpyio.intgpyiostndinfo.imdttrsffnncorgndsi.ImdtTrsfFnncOrgnDSI.selectImdtTrsfFnncOrgnInfo*/
		 
		            /*2020.11.04 모계좌번호 조회 추가*/
		            /*2021.10.06 즉시이체금융기관상세에 통화코드 컬럼 추가로 조회조건, 조회결과에 컬럼추가*/
		            /*2021.10.14 박현태: 외화데이터로 인한 다건 조회로 금융기 임시 PK 조건 추가 SQL 수정*/
                    /*2022.02.10 한화투자증권 배치용 모계좌처리 로직 수정(입출금모계좌번호 테이블에만 정보가있음)*/
                    /*2022.03.25 WITH절에 조회결과가 없을 때 모든 결과가 나오지않는 오류로 WITH절에 무조건 1ROW 조회되도록 수정*/

		            /*즉시이체금융기관정보조회*/

                    WITH VW_CRAN AS
                    ( SELECT PYIO_CRAN_SUID
                           , CRAN
                        FROM ( SELECT M.PYIO_CRAN_SUID
                                    , M.CRAN
                                 FROM IPMOWN.TBL_IPMIPDMACA M     /*입출금모계좌번호*/
                                WHERE 1 = 1
                                  AND M.FNNC_ORGN_CODE          = '269'
                                  AND M.CRPA_USE_BSWR_DVSN_CODE = '06'
                                  AND '20260529'     BETWEEN M.STAR_DTTM AND M.END_DTTM

                               UNION ALL

                               SELECT 3000000000701 AS PYIO_CRAN_SUID
                                    , 'mKkReLgaiVe' AS CRAN
                                 FROM DUAL
                        )
                       WHERE 1 = 1
                         AND ROWNUM = 1
                    )

		            SELECT A.FNNC_ORGN_DVSN_CODE           AS FNNC_ORGN_DVSN_CODE           /*  1.즉시이체금융기관_금융기관구분코드*/
		                 , A.FNNC_ORGN_CODE                AS FNNC_ORGN_CODE                /*  2.즉시이체금융기관_금융기관코드*/
		                 , A.HIST_SQNO                     AS HIST_SQNO                     /*  3.즉시이체금융기관_이력일련번호*/
		                 , A.BSWR_STRT_TME                 AS BSWR_STRT_TME                 /* 11.즉시이체금융기관_업무개시시간*/
		                 , A.BSWR_END_TME                  AS BSWR_END_TME                  /* 12.즉시이체금융기관_업무종료시간*/
		                 , A.IMDT_TRSF_CNVN_EXNE           AS IMDT_TRSF_CNVN_EXNE           /* 13.즉시이체금융기관_즉시이체협약유무*/
		                 , A.STAR_DTTM                     AS STAR_DTTM                     /* 14.즉시이체금융기관_시작일시*/
		                 , A.END_DTTM                      AS END_DTTM                      /* 15.즉시이체금융기관_종료일시*/
		                 , B.BSWR_DVSN_CODE                AS BSWR_DVSN_CODE                /*  1.즉시이체금융기관상세_업무구분코드*/
		                 , B.CRNY_CODE                     AS CRNY_CODE                     /*  5.즉시이체금융기관상세_통화코드*/
		                 , B.ETPS_CODE                     AS ETPS_CODE                     /* 13.즉시이체금융기관상세_업체코드*/
		 
 
       
		                 , B.DPST_IMDT_TRSF_CRAN_SUID      AS DPST_IMDT_TRSF_CRAN_SUID      /* 14.즉시이체금융기관상세_입금즉시이체모계좌번호SUID*/
		                 , B.FEE_WTMN_IMDT_TRSF_CRAN_SUID  AS FEE_WTMN_IMDT_TRSF_CRAN_SUID  /* 15.즉시이체금융기관상세_수수료인출즉시이체모계좌번호SUID*/
		                 , ( SELECT M.CRAN
		                       FROM IPMOWN.TBL_IPMIPDMACA M     /*입출금모계좌번호*/
		                      WHERE M.PYIO_CRAN_SUID = B.DPST_IMDT_TRSF_CRAN_SUID
		                        AND M.DLTN_YN = 'N'
		                        AND '20260529' BETWEEN M.STAR_DTTM AND M.END_DTTM
		                   )                               AS CRAN                          /* 15.모계좌번호*/
       
   
       
		              FROM IPMOWN.TBL_IPMIPDMAFO A     /*즉시이체금융기관*/
		                 , IPMOWN.TBL_IPMIPDMAFD B     /*즉시이체금융기관상세*/
		                 , VW_CRAN               C     /*한화투자증권 배치용 모계좌*/
		             WHERE 1 = 1
		              AND A.FNNC_ORGN_DVSN_CODE = B.FNNC_ORGN_DVSN_CODE
		              AND A.FNNC_ORGN_CODE      = B.FNNC_ORGN_CODE
		              AND A.CRNY_CODE           = B.CRNY_CODE
		              AND A.DLTN_YN             = 'N'
		              AND B.DLTN_YN             = 'N'
		              AND A.IMDT_TRSF_CNVN_EXNE = 'Y'
		              AND '20260529'               BETWEEN A.STAR_DTTM AND A.END_DTTM
		 
		         
		           
		              AND A.FNNC_ORGN_DVSN_CODE = '1'
		           
		         
		         
		           
